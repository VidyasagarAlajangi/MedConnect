## Backend environment variables (example)
# Copy to `backend/.env` and fill in real values. Never commit `.env`.

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/medconnect

# Auth
# Use a long random string (at least 32 chars)
JWT_SECRET=medi@123

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# AI (optional, used by /api/chat/ai)
GEMINI_API_KEY=replace-me

# VideoSDK (optional, used by /api/video/*)
VIDEOSDK_API_KEY=replace-me
VIDEOSDK_SECRET_KEY=replace-me

# Optional (development only): bootstrap an admin user on first login
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password

